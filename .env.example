# MongoDB Configuration
MONGODB_USER=progtalk_user
MONGODB_PASSWORD=progtalk_password
# Local container URI (used by docker compose)
MONGODB_URI=mongodb://progtalk_user:progtalk_password@mongo:27017/progtalk?authSource=admin

# JWT Secret
JWT_SECRET=your-secret-key-change-this-in-production

# Frontend Settings
FRONTEND_URL=https://localhost:5173

# Ports
BACKEND_PORT=3000
FRONTEND_PORT=5173
MONGO_PORT=27017
